@model HandlebarPractice.Models.CustomerVM

@{
    ViewData["Title"] = "Customer Setup";
}

<div class="container mt-4">

    <h3 class="mb-4">Customer Setup</h3>

    <!-- ================= CUSTOMER FORM CARD ================= -->
    <div class="card shadow-sm mb-4">
        <div class="card-header text-white" style="background-color:rgb(45 69 106)">
            Customer Information
        </div>

        <div class="card-body">

            <form asp-action="SaveCustomer" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Customer.SCustId" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Customer.SCustName" class="form-label"></label>
                        <input asp-for="Customer.SCustName" class="form-control" />
                        <span asp-validation-for="Customer.SCustName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Customer.SCustPhone" class="form-label"></label>
                        <input asp-for="Customer.SCustPhone" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Customer.SCustFax" class="form-label"></label>
                        <input asp-for="Customer.SCustFax" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Customer.SCustEmail" class="form-label"></label>
                        <input asp-for="Customer.SCustEmail" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Customer.SCustAddress1" class="form-label"></label>
                        <input asp-for="Customer.SCustAddress1" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Customer.SCustAddress2" class="form-label"></label>
                        <input asp-for="Customer.SCustAddress2" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Customer.SCustCity" class="form-label"></label>
                        <input asp-for="Customer.SCustCity" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Customer.SCustState" class="form-label"></label>
                        <input asp-for="Customer.SCustState" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Customer.SCustZip" class="form-label"></label>
                        <input asp-for="Customer.SCustZip" class="form-control" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Customer.SCustComments" class="form-label"></label>
                        <textarea asp-for="Customer.SCustComments" class="form-control" rows="3"></textarea>
                    </div>

                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">
                        @(Model.Customer.SCustId == 0 ? "Save Customer" : "Update Customer")
                    </button>
                    <a href="/HandleBar/Index" class="btn btn-secondary ms-2">Cancel</a>
                   @*  @if (Model.Customer.SCustId > 0)
                    {
                        
                    } *@
                </div>

            </form>

        </div>
    </div>
    <div class="mb-3 d-flex justify-content-end">
        <a href="/HandleBar/CustomerReport?lang=en" class="btn btn-info me-2" target="_blank">
            English Report
        </a>

        <a href="/HandleBar/CustomerReport?lang=bn" class="btn btn-success me-2" target="_blank">
            Bangla Report
        </a>

        <a href="/HandleBar/CustomerReport?variant=modern" class="btn btn-dark" target="_blank">
            Modern Report
        </a>
    </div>
 @*    <div class="mb-3">
        <a href="/HandleBar/CustomerReport?lang=en" class="btn btn-info me-2" target="_blank">
          
            English Report
        </a>

        <a href="/HandleBar/CustomerReport?lang=bn" class="btn btn-success me-2" target="_blank">
            
            Bangla Report
        </a>

        <a href="/HandleBar/CustomerReport?variant=modern" class="btn btn-dark me-2" target="_blank">
           
            Modern Report
        </a>
    </div> *@
    <div class="card shadow-sm">
        <div class="card-header text-white" style="background-color:rgb(120 126 131)">
            Customer List
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>City</th>
                            <th width="120">Action</th>
                        </tr>
                    </thead>

                    <tbody id="customerTableBody">
                       
                    </tbody>

                </table>

            </div>

        </div>
    </div>

    <script id="customer-template" type="text/x-handlebars-template">

        {{#if CustomerList.length}}

            {{#each CustomerList}}
            <tr>
                <td>{{SCustName}}</td>
                <td>{{SCustPhone}}</td>
                <td>{{SCustEmail}}</td>
                <td>{{SCustCity}}</td>

                <td>
                    <a href="/HandleBar/Index/{{SCustId}}" class="btn btn-sm btn-warning">
                        Edit
                    </a>

                    <a href="/HandleBar/Delete/{{SCustId}}"
                       class="btn btn-sm btn-danger"
                       onclick="return confirm('Delete this customer?');">
                        Delete
                    </a>
                </td>

            </tr>
            {{/each}}

        {{else}}

            <tr>
                <td colspan="5" class="text-center text-muted">
                    No customers found
                </td>
            </tr>

        {{/if}}

    </script>
   @*  <td>
        <a href="/HandleBar/Index/{{SCustId}}" class="btn btn-sm btn-warning">
            Edit
        </a>

        <a href="/HandleBar/Delete/{{SCustId}}"
           class="btn btn-sm btn-danger"
           onclick="return confirm('Delete this customer?');">
            Delete
        </a>

        <!-- PDF Button -->
        <a href="/HandleBar/CustomerPdf/{{SCustId}}"
           class="btn btn-sm btn-primary ms-1"
           target="_blank">
            PDF
        </a>
    </td> *@

</div>


@section Scripts {

    <partial name="_ValidationScriptsPartial" />


    <script>

        $(document).ready(function () {

            
            var customerData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

            var source = document.getElementById("customer-template").innerHTML;

            var template = Handlebars.compile(source);

            var html = template(customerData);

            $("#customerTableBody").html(html);

        });

    </script>

}